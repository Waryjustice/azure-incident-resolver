# Azure Incident Resolver — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it is listed in .gitignore.

# ─── Azure Subscription ───────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_RESOURCE_GROUP=azure-incident-resolver-rg
AZURE_LOCATION=southeastasia

# ─── Azure SQL Database ───────────────────────────────────────────────────────
AZURE_SQL_SERVER=your-sql-server.database.windows.net
AZURE_SQL_DATABASE=your-database-name

# ─── Azure App Service ────────────────────────────────────────────────────────
# Full resource ID of the web app to monitor and remediate
MONITORED_WEBAPP_ID=/subscriptions/your-subscription-id/resourceGroups/your-rg/providers/Microsoft.Web/sites/your-app-name
# Optional: short name override (derived from MONITORED_WEBAPP_ID if not set)
# AZURE_WEBAPP_NAME=your-app-name

# ─── Azure Monitor ────────────────────────────────────────────────────────────
AZURE_MONITOR_WORKSPACE_ID=your-log-analytics-workspace-id
AZURE_APP_INSIGHTS_KEY=your-app-insights-instrumentation-key
AZURE_APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/

# ─── Azure Service Bus (MCP message queues between agents) ───────────────────
AZURE_SERVICEBUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-shared-access-key

# ─── GitHub (for PR creation and GitHub Models AI) ───────────────────────────
# Personal Access Token with repo scope — also used for GitHub Models inference
GITHUB_TOKEN=ghp_your-github-personal-access-token
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=azure-incident-resolver

# ─── GitHub Models AI (gpt-4o-mini via azure-ai-inference SDK) ───────────────
# The system uses GITHUB_TOKEN above for authentication — no separate key needed.
# Endpoint: https://models.inference.ai.azure.com  (hardcoded in diagnosis agent)
GITHUB_MODEL_NAME=gpt-4o-mini

# ─── Azure AI Foundry (optional — not used at runtime) ───────────────────────
# Originally planned for Foundry; pivoted to GitHub Models due to student account
# region restrictions. These vars are kept for completeness but not called.
FOUNDRY_ENDPOINT=https://your-foundry-instance.services.ai.azure.com/
FOUNDRY_API_KEY=your-foundry-api-key

# ─── Azure OpenAI (optional — not used at runtime) ───────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-foundry-instance.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# ─── Microsoft Teams (removed — not used) ────────────────────────────────────
# TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/your-webhook

# ─── Agent Configuration ──────────────────────────────────────────────────────
DETECTION_AGENT_INTERVAL_SECONDS=60
DIAGNOSIS_TIMEOUT_SECONDS=300
# Set to true to auto-apply fixes without human PR review (not recommended in production)
RESOLUTION_AUTO_APPROVE=false

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── Flask Dashboard ──────────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-this-to-a-random-secret-in-production
